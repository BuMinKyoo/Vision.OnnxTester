<Window x:Class="Vision.OnnxTester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Vision.OnnxTester.ViewModels"
        xmlns:models="clr-namespace:Vision.OnnxTester.Models"
        mc:Ignorable="d"
        Title="Vision.OnnxTester (YOLOv8)" Height="720" Width="1100">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 툴바 -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="이미지 열기..."
                    Command="{Binding LoadImageCommand}"
                    Width="120" Height="32"/>
            <Button Content="객체 검출"
                    Command="{Binding DetectCommand}"
                    Width="120" Height="32" Margin="8,0,0,0"/>
            <Button Content="취소"
                    Command="{Binding CancelCommand}"
                    Width="80" Height="32" Margin="8,0,0,0"/>
            <ProgressBar Width="120" Height="14" Margin="12,0,0,0"
                         IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{Binding ImagePath}"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       Foreground="Gray" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- 좌: 이미지 + 박스 오버레이 -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="#888" BorderThickness="1" Background="#222"
                Margin="0,0,8,0">
            <Viewbox Stretch="Uniform">
                <Grid Width="{Binding ImageWidth}" Height="{Binding ImageHeight}">
                    <Image Source="{Binding ImageSource}" Stretch="Fill"/>

                    <!-- 검출 결과 박스 -->
                    <ItemsControl ItemsSource="{Binding Detections}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:Detection}">
                                <Grid Width="{Binding Width}" Height="{Binding Height}">
                                    <Rectangle Stroke="LimeGreen" StrokeThickness="3"/>
                                    <Border Background="LimeGreen"
                                            VerticalAlignment="Top" HorizontalAlignment="Left"
                                            Padding="3,1">
                                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="Black">
                                            <Run Text="{Binding ClassName, Mode=OneWay}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Confidence, StringFormat={}{0:P0}, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Viewbox>
        </Border>

        <!-- 우: 검출 결과 리스트 -->
        <DockPanel Grid.Row="1" Grid.Column="1">
            <TextBlock DockPanel.Dock="Top" Text="검출 결과" FontWeight="Bold" Margin="0,0,0,4"/>
            <ListBox ItemsSource="{Binding Detections}"
                     FontFamily="Consolas" FontSize="12">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:Detection}">
                        <StackPanel>
                            <TextBlock>
                                <Run Text="{Binding ClassName, Mode=OneWay}" FontWeight="Bold"/>
                                <Run Text="  "/>
                                <Run Text="{Binding Confidence, StringFormat={}{0:P1}, Mode=OneWay}" Foreground="DarkGreen"/>
                            </TextBlock>
                            <TextBlock Foreground="Gray">
                                <Run Text="x="/>
                                <Run Text="{Binding X, StringFormat={}{0:F0}, Mode=OneWay}"/>
                                <Run Text=" y="/>
                                <Run Text="{Binding Y, StringFormat={}{0:F0}, Mode=OneWay}"/>
                                <Run Text=" w="/>
                                <Run Text="{Binding Width, StringFormat={}{0:F0}, Mode=OneWay}"/>
                                <Run Text=" h="/>
                                <Run Text="{Binding Height, StringFormat={}{0:F0}, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- 하단 상태바 -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#EEE" Margin="0,8,0,0" Padding="8,4">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#333"/>
        </Border>
    </Grid>
</Window>
